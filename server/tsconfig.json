{
  "compilerOptions": {
    "module": "NodeNext",
    "moduleResolution": "NodeNext",
    "target": "ES2022",
    "strict": true,
    "esModuleInterop": true,
    "skipLibCheck": true,
    "allowSyntheticDefaultImports": true,
    "resolveJsonModule": true,
    "isolatedModules": true,
    "rootDir": "..",
    "outDir": "../dist-server",
    "types": ["node"]
  },
  "include": ["../api/**/*.ts", "./**/*.ts"],
  "exclude": [
    "../node_modules/**",
    "../dist/**",
    "../api/**/*.test.ts",
    "../api/**/*.spec.ts",
    "./**/*.test.ts"
  ]
}
