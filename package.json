{
  "name": "universal-pensions-uganda",
  "private": true,
  "version": "1.0.0",
  "description": "Landing page and dashboard for Universal Pensions Uganda — a digital pension platform making retirement savings accessible for every Ugandan.",
  "type": "module",
  "engines": {
    "node": "22.x"
  },
  "scripts": {
    "dev": "vite",
    "dev:api": "sh -c 'set -a; [ -f .env.local ] && . ./.env.local; set +a; exec vercel dev'",
    "build": "vite build",
    "lint": "eslint .",
    "preview": "vite preview",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:e2e": "playwright test",
    "test:e2e:headed": "playwright test --headed",
    "test:e2e:ui": "playwright test --ui",
    "test:e2e:smoke": "playwright test e2e/specs/smoke",
    "test:e2e:flows": "playwright test e2e/specs/flows",
    "seed": "node scripts/seed-supabase.mjs"
  },
  "dependencies": {
    "@supabase/supabase-js": "^2.105.4",
    "@tanstack/react-query": "^5.96.2",
    "@tanstack/react-virtual": "^3.13.23",
    "dotenv": "^17.4.2",
    "framer-motion": "^12.38.0",
    "jose": "^6.2.3",
    "leaflet": "^1.9.4",
    "pg": "^8.20.0",
    "react": "^19.2.4",
    "react-dom": "^19.2.4",
    "react-is": "^19.2.6",
    "react-leaflet": "^5.0.0",
    "react-router-dom": "^7.14.0",
    "recharts": "^3.8.1"
  },
  "devDependencies": {
    "@eslint/js": "^9.39.4",
    "@playwright/test": "^1.60.0",
    "@testing-library/dom": "^10.4.1",
    "@testing-library/jest-dom": "^6.9.1",
    "@testing-library/react": "^16.3.2",
    "@testing-library/user-event": "^14.6.1",
    "@turf/turf": "^7.3.4",
    "@types/react": "^19.2.14",
    "@types/react-dom": "^19.2.3",
    "@vitejs/plugin-react": "^4.5.2",
    "eslint": "^9.39.4",
    "eslint-plugin-react-hooks": "^7.0.1",
    "eslint-plugin-react-refresh": "^0.5.2",
    "globals": "^17.4.0",
    "jsdom": "^29.0.2",
    "supabase": "^2.98.2",
    "vercel": "^54.0.0",
    "vite": "^6.3.5",
    "vitest": "^4.1.4"
  }
}
