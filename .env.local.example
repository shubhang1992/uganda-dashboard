# Copy this file to `.env.local` and fill in the values from your Supabase project.
# `.env.local` is gitignored — never commit real secrets.

# === Frontend (public, safe to expose) ===
VITE_SUPABASE_URL=https://<your-project-ref>.supabase.co
VITE_SUPABASE_ANON_KEY=<your-anon-public-key>

# Rollback feature flag. Set to false to bypass Supabase and fall back to mock data.
VITE_USE_SUPABASE=true

# API base URL for the frontend.
#   Local dev:           http://localhost:3001/api  (Express via `npm run dev:api`)
#   Production/Preview:  set in Vercel project env to https://<your-render-host>/api
# Vite bakes this value at build time, so changing it requires a redeploy
# (per-environment values can diverge: staging Render vs prod Render).
# VITE_API_BASE_URL=http://localhost:3001/api

# Public marketing / support URLs. Defaults in `src/config/env.js` apply when unset.
# VITE_LEGAL_TERMS_URL=https://universalpensions.com/legal/terms
# VITE_LEGAL_PRIVACY_URL=https://universalpensions.com/legal/privacy
# VITE_SUPPORT_WHATSAPP_URL=https://wa.me/256700123456
# VITE_SUPPORT_WHATSAPP_DISPLAY=+256 700 123 456
# VITE_SUPPORT_EMAIL=support@upensions.ug

# Map tile provider — defaults to CartoDB Positron. Override for self-hosted tiles.
# VITE_MAP_TILE_URL=https://{s}.basemaps.cartocdn.com/light_nolabels/{z}/{x}/{y}{r}.png

# Frontend Sentry. Both are consumed in src/main.jsx + src/components/ErrorBoundary.jsx
# and gated on VITE_SENTRY_DSN — when unset, frontend Sentry init is a silent no-op
# (local dev, PR previews). Set these in the Vercel project env for production.
#   VITE_SENTRY_RELEASE can be wired to Vercel's VERCEL_GIT_COMMIT_SHA for
#   release-health grouping; without it events are released as `undefined`.
# VITE_SENTRY_DSN=https://<key>@<org>.ingest.sentry.io/<project>
# VITE_SENTRY_RELEASE=<git-commit-sha-or-version>

# === Backend only (server-side; never prefix with VITE_) ===
# Server-side name for the Supabase project URL (server/env.ts treats it as canonical;
# render.yaml provisions it in production). server/env.ts currently falls back to
# VITE_SUPABASE_URL during the Vercel→Render cutover, but that fallback is marked for
# removal — set SUPABASE_URL so local `npm run dev:api` keeps booting once it's gone.
SUPABASE_URL=https://<your-project-ref>.supabase.co
SUPABASE_SERVICE_ROLE_KEY=<your-service-role-key>
SUPABASE_JWT_SECRET=<your-jwt-secret-from-project-settings-api-jwt-settings>

# === Server (used by api/, not loaded by Vite) ===
# Port the Express dev server (server/index.ts) binds to. Must match the port
# in VITE_API_BASE_URL above. Render injects its own PORT in production.
PORT=3001

# Optional. Sentry server-side DSN. Leave unset to skip Sentry init entirely
# (local dev, PR previews). Set on Render for production observability.
# SENTRY_DSN=https://<key>@<org>.ingest.sentry.io/<project>

# Optional. Server-side Sentry release tag (server/index.ts). On Render the
# auto-injected RENDER_GIT_COMMIT is preferred, so this is only a manual override
# for non-Render hosts; without either, server events release as `undefined`.
# SENTRY_RELEASE=<git-commit-sha-or-version>

# === Local-only — used by the seed script ===
# From Project Settings → Database → Connection pooling (Transaction mode, port 6543).
SUPABASE_DB_URL=postgresql://postgres.<project-ref>:<password>@aws-0-<region>.pooler.supabase.com:6543/postgres

# === Local-only — used by `npm run deploy:api` (scripts/render-deploy.mjs) ===
# Render manual-deploy hook. From the Render dashboard → service → Settings → Deploy Hook.
# Leave unset unless you trigger backend deploys from this machine.
# RENDER_DEPLOY_HOOK=https://api.render.com/deploy/srv-...?key=...

# === Note: supabase/config.toml local-auth password policy ===
# `supabase/config.toml` sets [auth] minimum_password_length=6 / password_requirements=""
# for the Supabase CLI local-dev stack only. The app does NOT use Supabase Auth (it
# uses a custom HS256 JWT), so that setting is inert — the real password policy lives
# in api/auth/_lib/password.ts. No env var to set here; documented to avoid confusion.
